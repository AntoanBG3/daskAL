@page "/search"
@using Microsoft.EntityFrameworkCore
@using SchoolManagementSystem.Web.Data
@using SchoolManagementSystem.Web.Models
@using SchoolManagementSystem.Web.Models.ViewModels
@inject SchoolDbContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>Search Results - daskAL</PageTitle>

<div class="container-fluid search-page">
    <div class="page-header mb-4">
        <h1><i class="bi bi-search"></i>Search Results</h1>
        <p class="page-subtitle">
            @if (HasQuery)
            {
                <span>
                    Showing results for <span class="fw-semibold text-dark">"@Q"</span>
                    @if (!string.IsNullOrEmpty(Type) && Type != "All")
                    {
                        <span>in <span class="fw-semibold text-dark">@Type</span></span>
                    }
                </span>
            }
            else
            {
                <span>Use the top search bar to find students, teachers, and classes.</span>
            }
        </p>
    </div>

    @if (IsLoading)
    {
        <div class="d-flex justify-content-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!HasQuery)
    {
        <div class="card-premium empty-state search-empty-state">
            <i class="bi bi-search"></i>
            <h5>Start with a search term</h5>
            <p>Try a student's name, teacher name, or class code like 10A.</p>
            <a href="/" class="btn btn-outline-primary mt-2">Back to Dashboard</a>
        </div>
    }
    else if (!HasResults)
    {
        <div class="card-premium empty-state search-empty-state">
            <i class="bi bi-search"></i>
            <h5>No results found</h5>
            <p>We couldn't find anything matching your search. Try different keywords.</p>
            <a href="/" class="btn btn-outline-primary mt-2">Back to Dashboard</a>
        </div>
    }
    else
    {
        <div class="row g-4 search-results-grid">
            @if (Students.Any())
            {
                <div class="col-12">
                    <div class="search-section-title">
                        <h5><i class="bi bi-people"></i>Students</h5>
                        <span class="badge bg-light text-dark">@Students.Count</span>
                    </div>
                </div>
                @foreach (var s in Students)
                {
                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <div class="card-premium search-result-card h-100">
                            <div class="d-flex align-items-center mb-3">
                                <div class="card-icon bg-light text-primary me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                                    <i class="bi bi-person-circle"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">@s.FirstName @s.LastName</h6>
                                    <small class="text-muted">ID: @s.Id</small>
                                </div>
                            </div>
                            <div class="mt-auto">
                                <a href="students/edit/@s.Id" class="btn btn-sm btn-outline w-100">View Profile</a>
                            </div>
                        </div>
                    </div>
                }
            }

            @if (Teachers.Any())
            {
                <div class="col-12 mt-4">
                    <div class="search-section-title">
                        <h5><i class="bi bi-person-badge"></i>Teachers</h5>
                        <span class="badge bg-light text-dark">@Teachers.Count</span>
                    </div>
                </div>
                @foreach (var t in Teachers)
                {
                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <div class="card-premium search-result-card h-100">
                             <div class="d-flex align-items-center mb-3">
                                <div class="card-icon bg-light text-warning me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                                    <i class="bi bi-person-badge-fill"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">@t.FirstName @t.LastName</h6>
                                    <small class="text-muted">Teacher</small>
                                </div>
                            </div>
                             <div class="mt-auto">
                                <a href="teachers/edit/@t.Id" class="btn btn-sm btn-outline w-100">View Details</a>
                            </div>
                        </div>
                    </div>
                }
            }

            @if (Classes.Any())
            {
                <div class="col-12 mt-4">
                    <div class="search-section-title">
                        <h5><i class="bi bi-building"></i>Classes</h5>
                        <span class="badge bg-light text-dark">@Classes.Count</span>
                    </div>
                </div>
                @foreach (var c in Classes)
                {
                    <div class="col-md-6 col-lg-4 col-xl-3">
                        <div class="card-premium search-result-card h-100">
                             <div class="d-flex align-items-center mb-3">
                                <div class="card-icon bg-light text-info me-3" style="width: 40px; height: 40px; font-size: 1.2rem;">
                                    <i class="bi bi-building"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">@c.Name</h6>
                                    <small class="text-muted">Class</small>
                                </div>
                            </div>
                             <div class="mt-auto">
                                <a href="classes/edit/@c.Id" class="btn btn-sm btn-outline w-100">Manage Class</a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Q { get; set; }

    [SupplyParameterFromQuery]
    public string? Type { get; set; }

    private List<Student> Students = new();
    private List<Teacher> Teachers = new();
    private List<SchoolClass> Classes = new();
    private bool IsLoading = true;
    private bool HasQuery => !string.IsNullOrWhiteSpace(Q);
    private bool HasResults => Students.Any() || Teachers.Any() || Classes.Any();

    protected override async Task OnParametersSetAsync()
    {
        IsLoading = true;
        await PerformSearch();
        IsLoading = false;
    }

    private async Task PerformSearch()
    {
        Students.Clear();
        Teachers.Clear();
        Classes.Clear();

        if (string.IsNullOrWhiteSpace(Q)) return;

        var term = Q.ToLower();

        if (string.IsNullOrEmpty(Type) || Type == "All" || Type == "Students")
        {
            Students = await DbContext.Students
                .Where(s => s.FirstName.ToLower().Contains(term) || s.LastName.ToLower().Contains(term))
                .ToListAsync();
        }

        if (string.IsNullOrEmpty(Type) || Type == "All" || Type == "Teachers")
        {
            Teachers = await DbContext.Teachers
                .Where(t => t.FirstName.ToLower().Contains(term) || t.LastName.ToLower().Contains(term))
                .ToListAsync();
        }

        if (string.IsNullOrEmpty(Type) || Type == "All" || Type == "Classes")
        {
            Classes = await DbContext.SchoolClasses
                .Where(c => c.Name.ToLower().Contains(term))
                .ToListAsync();
        }
    }
}
