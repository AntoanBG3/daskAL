@page "/settings"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IJSRuntime JSRuntime

<PageTitle>Settings - daskAL</PageTitle>

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="d-flex align-items-center mb-4">
            <h1 class="h3 mb-0 me-3">Settings</h1>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <h5 class="card-title mb-0 fw-bold"><i class="bi bi-palette me-2"></i> Appearance</h5>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <label class="form-label fw-semibold mb-3">Sidebar Theme</label>
                    @if (currentTheme == null)
                    {
                         <div class="d-flex justify-content-center py-4">
                             <div class="spinner-border text-primary spinner-border-sm" role="status">
                                 <span class="visually-hidden">Loading...</span>
                             </div>
                         </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" role="switch" id="darkModeSwitch"
                                       checked="@(currentTheme == "dark")"
                                       @onchange="ToggleTheme"
                                       style="width: 3em; height: 1.5em; cursor: pointer;">
                                <label class="form-check-label ms-2" for="darkModeSwitch" style="font-weight: 500; cursor: pointer; padding-top: 2px;">
                                    @(currentTheme == "dark" ? "Dark Mode Enabled" : "Dark Mode Disabled")
                                </label>
                            </div>
                        </div>
                        <div class="mt-3 text-muted small">
                            <i class="bi bi-info-circle me-1"></i> Switch between Light and Dark sidebar themes.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string? currentTheme;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try 
            {
                currentTheme = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "sidebarTheme");
                if (string.IsNullOrEmpty(currentTheme) || currentTheme == "default")
                {
                    currentTheme = "light";
                }
                StateHasChanged();
            }
            catch
            {
                currentTheme = "light";
                StateHasChanged();
            }
        }
    }

    private async Task ToggleTheme(ChangeEventArgs e)
    {
        bool isDark = (bool)(e.Value ?? false);
        string newTheme = isDark ? "dark" : "light";
        await SetTheme(newTheme);
    }

    private async Task SetTheme(string theme)
    {
        currentTheme = theme;
        await JSRuntime.InvokeVoidAsync("setTheme", theme);
    }
}
