@page "/classes"
@inject IClassService ClassService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@using SchoolManagementSystem.Web.Models.ViewModels

<PageTitle>Classes - daskAL</PageTitle>

<div class="page-header d-flex align-items-start justify-content-between">
    <div>
        <h1><i class="bi bi-building"></i> School Classes</h1>
        <p class="page-subtitle">Manage classes and their subject assignments.</p>
    </div>
    <a href="classes/add" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add New Class
    </a>
</div>

@if (classes == null)
{
    <div class="spinner-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!classes.Any())
{
    <div class="empty-state">
        <i class="bi bi-building"></i>
        <h5>No classes found</h5>
        <p>Click "Add New Class" to create one.</p>
    </div>
}
else
{
    <div class="card-table">
        <div class="table-responsive">
            <table class="table table-modern mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Name</th>
                        <th>Assigned Subjects</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in classes)
                    {
                        <tr>
                            <td class="ps-4 align-middle fw-bold">@c.Name</td>
                            <td class="align-middle">
                                @if(c.AssignedSubjects.Any())
                                {
                                    @foreach(var subject in c.AssignedSubjects)
                                    {
                                        <span class="badge-subject">@subject</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">No subjects assigned</span>
                                }
                            </td>
                            <td class="text-end pe-4 align-middle">
                                <div class="btn-group">
                                    <a href="classes/edit/@c.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil-fill me-1"></i> Manage
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<SchoolClassViewModel>? classes;

    protected override async Task OnInitializedAsync()
    {
        classes = await ClassService.GetAllClassesAsync();
    }
}
