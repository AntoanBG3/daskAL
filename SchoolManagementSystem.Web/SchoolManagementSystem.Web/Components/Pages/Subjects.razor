@page "/subjects"
@attribute [Authorize(Roles = "Admin,Teacher")]
@inject ISubjectService SubjectService
@inject IJSRuntime JSRuntime
@using SchoolManagementSystem.Web.Models.ViewModels

<PageTitle>Subjects - daskAL</PageTitle>

<div class="page-header d-flex align-items-start justify-content-between">
    <div>
        <h1><i class="bi bi-book"></i> Subjects</h1>
        <p class="page-subtitle">Manage subject catalog and teacher assignments.</p>
    </div>
    <a href="subjects/add" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Subject
    </a>
</div>

@if (subjects == null)
{
    <div class="spinner-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!subjects.Any())
{
    <div class="empty-state">
        <i class="bi bi-book"></i>
        <h5>No subjects found</h5>
        <p>Get started by adding your first subject.</p>
    </div>
}
else
{
    <div class="card-table">
        <div class="table-responsive">
            <table class="table table-modern mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Name</th>
                        <th>Description</th>
                        <th>Teacher</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var subject in subjects)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@subject.Name</td>
                            <td class="text-muted">@subject.Description</td>
                            <td>
                                @if (!string.IsNullOrEmpty(subject.TeacherName))
                                {
                                    <span>@subject.TeacherName</span>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Unassigned</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a href="/subjects/edit/@subject.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil-fill me-1"></i> Edit
                                    </a>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSubject(subject.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<SubjectViewModel>? subjects;

    protected override async Task OnInitializedAsync()
    {
        await LoadSubjects();
    }

    private async Task LoadSubjects()
    {
        subjects = await SubjectService.GetAllSubjectsAsync();
    }
    
    private async Task DeleteSubject(int id)
    {
         if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this subject?"))
        {
            await SubjectService.DeleteSubjectAsync(id);
            await LoadSubjects();
        }
    }
}
