@page "/students"
@attribute [Authorize(Roles = "Admin,Teacher")]
@inject IStudentService StudentService
@inject IJSRuntime JSRuntime
@using SchoolManagementSystem.Web.Models.ViewModels

<PageTitle>Students - daskAL</PageTitle>

<div class="page-header d-flex align-items-start justify-content-between">
    <div>
        <h1><i class="bi bi-people"></i> Students</h1>
        <p class="page-subtitle">View and manage all registered students.</p>
    </div>
    <a href="students/add" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Student
    </a>
</div>

@if (students == null)
{
    <div class="spinner-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!students.Any())
{
    <div class="empty-state">
        <i class="bi bi-people"></i>
        <h5>No students found</h5>
        <p>Get started by adding your first student.</p>
    </div>
}
else
{
    <div class="card-table">
        <div class="table-responsive">
            <table class="table table-modern mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Name</th>
                        <th>Class</th>
                        <th>Date of Birth</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in students)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@student.FirstName @student.LastName</td>
                            <td>
                                @if (!string.IsNullOrEmpty(student.Class))
                                {
                                    <span class="badge-subject">@student.Class</span>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Unassigned</span>
                                }
                            </td>
                            <td>@student.DateOfBirth.ToShortDateString()</td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a href="/students/edit/@student.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil-fill me-1"></i> Edit
                                    </a>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteStudent(student.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<StudentViewModel>? students;

    protected override async Task OnInitializedAsync()
    {
        await LoadStudents();
    }

    private async Task LoadStudents()
    {
        students = await StudentService.GetAllStudentsAsync();
    }

    private async Task DeleteStudent(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this student?"))
        {
            await StudentService.DeleteStudentAsync(id);
            await LoadStudents();
        }
    }
}
