@page "/teachers"
@attribute [Authorize(Roles = "Admin")]
@inject ITeacherService TeacherService
@inject IJSRuntime JSRuntime
@using SchoolManagementSystem.Web.Models.ViewModels

<PageTitle>Teachers - daskAL</PageTitle>

<div class="page-header d-flex align-items-start justify-content-between">
    <div>
        <h1><i class="bi bi-person-badge"></i> Teachers</h1>
        <p class="page-subtitle">View teachers and their assigned subjects.</p>
    </div>
    <a href="teachers/add" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Add Teacher
    </a>
</div>

@if (teachers == null)
{
    <div class="spinner-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!teachers.Any())
{
    <div class="empty-state">
        <i class="bi bi-person-badge"></i>
        <h5>No teachers found</h5>
        <p>Get started by adding your first teacher.</p>
    </div>
}
else
{
    <div class="card-table">
        <div class="table-responsive">
            <table class="table table-modern mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Name</th>
                        <th>Subjects</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var teacher in teachers)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@teacher.FullName</td>
                            <td>
                                @if (teacher.TeachingSubjects.Any())
                                {
                                    @foreach (var subject in teacher.TeachingSubjects)
                                    {
                                        <span class="badge-subject">@subject</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">No subjects assigned</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a href="/teachers/edit/@teacher.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-pencil-fill me-1"></i> Edit
                                    </a>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTeacher(teacher.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<TeacherViewModel>? teachers;

    protected override async Task OnInitializedAsync()
    {
        await LoadTeachers();
    }

    private async Task LoadTeachers()
    {
        teachers = await TeacherService.GetAllTeachersAsync();
    }

    private async Task DeleteTeacher(int id)
    {
         if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this teacher?"))
        {
            await TeacherService.DeleteTeacherAsync(id);
            await LoadTeachers();
        }
    }
}
